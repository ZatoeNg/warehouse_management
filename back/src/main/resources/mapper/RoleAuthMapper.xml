<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.mapper.RoleAuthMapper">

  <delete id="removeRoleAuthByRid">
    DELETE FROM role_auth
    WHERE role_id = #{roleId}
  </delete>

  <select id="findAuthIdsByRid" resultType="java.lang.Integer">
    SELECT auth_id FROM role_auth
    WHERE role_id =#{roleId}
  </select>

  <insert id="insertRoleAuth">
    INSERT INTO role_auth
    VALUES (
      null,#{roleId},#{authId}
    )
  </insert>
</mapper>